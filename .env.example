# LMS-SOP Environment Configuration
# Hostinger Deployment

# Server
PORT=5000
NODE_ENV=production

# Database (phpMyAdmin remote MySQL on Hostinger)
DB_HOST=srv1980.hstgr.io
DB_USER=u591572634_reservist
DB_PASSWORD=your_hostinger_db_password
DB_NAME=lms_sop
DB_PORT=3306

# Authentication
JWT_SECRET=change-this-in-production-use-a-long-random-string

# CORS (add your Hostinger domain after deployment)
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# File Storage (local disk for Hostinger)
UPLOAD_DIR=uploads

# Email/SMTP (optional - Hostinger SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Hostinger Remote MySQL Notes:
# - Enable remote MySQL access in Hostinger phpMyAdmin
# - Whitelist your server IP in Hostinger MySQL settings
# - The DB_HOST should be the remote MySQL hostname from Hostinger