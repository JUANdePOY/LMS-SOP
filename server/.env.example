PORT=5000
DB_HOST=your_hostinger_remote_mysql_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=3306
JWT_SECRET=change-this-in-production-use-a-long-random-string
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173
NODE_ENV=production

# Hostinger Remote MySQL Notes:
# - Enable remote MySQL access in Hostinger phpMyAdmin
# - Whitelist your server IP in Hostinger MySQL settings
# - The DB_HOST should be the remote MySQL hostname from Hostinger
